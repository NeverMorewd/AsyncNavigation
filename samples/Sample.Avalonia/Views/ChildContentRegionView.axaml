<UserControl
    x:Class="Sample.Avalonia.Views.ChildContentRegionView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:an="https://github.com/NeverMorewd/AsyncNavigation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Sample.Common"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:ChildContentRegionViewModel"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Border
            HorizontalAlignment="Stretch"
            Background="GreenYellow"
            BorderBrush="BurlyWood"
            BorderThickness="1"
            DockPanel.Dock="Top">
            <StackPanel>
                <TextBlock Text="{Binding Name}" />
                <TextBlock>
                    InstanceNumber:<Run
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="Tomato"
                        Text="{Binding InstanceNumber}" />
                </TextBlock>
                <Button Classes="UnloadView" />
                <Button Classes="CloseDialog" />
            </StackPanel>
        </Border>
        <StackPanel Orientation="Vertical">
            <Button
                Classes="Navigation"
                Content="ToLightView"
                Tag="LightView" />
            <Button
                Classes="Navigation"
                Content="ToHeavyView"
                Tag="HeavyView" />
        </StackPanel>
        <ContentControl an:RegionManager.RegionName="ChildContentRegion" />
    </DockPanel>
</UserControl>

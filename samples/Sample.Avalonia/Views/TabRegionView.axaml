<UserControl
    x:Class="Sample.Avalonia.Views.TabRegionView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:an="https://github.com/NeverMorewd/AsyncNavigation"
    xmlns:ancore="using:AsyncNavigation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Sample.Common"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:TabRegionViewModel"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="GoBack" />
                <Button Classes="GoForward" />
            </StackPanel>
            <Button
                Classes="Navigation"
                Content="ToLightView"
                Tag="LightView" />
            <Button
                Classes="Navigation"
                Content="ToHeavyView"
                Tag="HeavyView" />
            <Button
                Classes="Navigation"
                Content="ToHeavyView:Delay"
                Tag="HeavyView:Delay" />
            <Button
                Classes="Navigation"
                Content="ToLightView:New"
                Tag="LightView:New" />
            <Button
                Classes="Navigation"
                Content="ToHeavyView:New;Delay"
                Tag="HeavyView:New;Delay" />
            <Button
                Classes="NavigationAndForget"
                Content="ToLightView:Forget"
                Tag="LightView" />
            <Button
                Classes="NavigationAndForget"
                Content="ToLightView:Forget;New"
                Tag="LightView:New" />
        </StackPanel>
        <ScrollViewer>
            <TabControl
                Name="tab"
                an:RegionManager.PreferCache="True"
                an:RegionManager.RegionName="TabRegion"
                TabStripPlacement="Top">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            Margin="2"
                            Orientation="Horizontal"
                            Spacing="4">
                            <ContentControl Content="{ReflectionBinding Target.Value.DataContext.Icon, Converter={StaticResource IconDescriptorConverter}}" />
                            <TextBlock VerticalAlignment="Center" Text="{ReflectionBinding ViewName}" />
                            <Button
                                Margin="10"
                                Command="{ReflectionBinding DataContext.RequestUnloadViewCommand,
                                                            ElementName=tab}"
                                CommandParameter="{Binding}"
                                Content="x" />
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>

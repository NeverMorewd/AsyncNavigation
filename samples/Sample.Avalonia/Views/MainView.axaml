<UserControl
    x:Class="Sample.Avalonia.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:an="https://github.com/NeverMorewd/AsyncNavigation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sample.Common;assembly=Sample.Common"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="*,30">
        <SplitView
            DisplayMode="CompactInline"
            IsPaneOpen="{Binding IsSplitViewPaneOpen}"
            OpenPaneLength="310"
            PanePlacement="Right">
            <SplitView.Pane>
                <DockPanel>
                    <ToggleButton
                        Width="45"
                        HorizontalContentAlignment="Center"
                        Classes="Switch"
                        DockPanel.Dock="Top"
                        IsChecked="{Binding IsSplitViewPaneOpen}"
                        ZIndex="99" />
                    <StackPanel Classes="Navigation" IsVisible="{Binding IsSplitViewPaneOpen}">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="3">
                            <Label VerticalAlignment="Center" Content="Search:" />
                            <AutoCompleteBox
                                Name="SearchBox"
                                Width="230"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding Views}"
                                SelectedItem="{Binding SelectedView}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Classes="GoBack" />
                            <Button Classes="GoForward" />
                        </StackPanel>
                        <Button
                            Classes="Navigation"
                            Content="ToLightView"
                            Tag="LightView" />
                        <Button
                            Classes="Navigation"
                            Content="ToHeavyView"
                            Tag="HeavyView" />
                        <Button
                            Classes="Navigation"
                            Content="ToHeavyView:Delay"
                            Tag="HeavyView:Delay" />
                        <Button
                            Classes="Navigation"
                            Content="ToLightView:New"
                            Tag="LightView:New" />
                        <Button
                            Classes="Navigation"
                            Content="ToHeavyView:Error"
                            Tag="HeavyView:Error" />
                        <Button
                            Classes="NavigationAndForget"
                            Content="ToLightView:Forget;New"
                            Tag="LightView:New" />
                        <Button
                            Classes="NavigationAndForget"
                            Content="ToHeavyView:Forget;Delay"
                            Tag="HeavyView:Delay" />
                        <Button
                            Classes="Navigation"
                            Content="ToItemsRegionView"
                            Tag="ItemsRegionView" />
                        <Button
                            Classes="Navigation"
                            Content="ToTabRegionView"
                            Tag="TabRegionView" />
                        <Button
                            Classes="Navigation"
                            Content="ToChildContentRegionView"
                            Tag="ChildContentRegionView" />
                        <Button
                            Classes="Navigation"
                            Content="ToListBoxRegionView"
                            Tag="ListBoxRegionView" />
                        <Button
                            Classes="Navigation"
                            Content="ToNavigationPage"
                            Tag="NavigationPageView" />
                        <Button
                            Classes="Navigation"
                            Content="ToTabbedPage"
                            Tag="TabbedPageView" />
                        <Button
                            Classes="DialogShow"
                            Content="ToLightView:Dialog.Show"
                            Tag="LightView" />
                        <Button
                            Classes="DialogShow"
                            Content="ToHeavyView:Dialog.Show"
                            Tag="HeavyView" />
                        <Button
                            Classes="DialogShowDialog"
                            Content="ToLightView:Dialog.ShowDialog"
                            Tag="LightView" />
                        <Button
                            Classes="DialogShowDialogAsync"
                            Content="ToHeavyView:Dialog.AsyncShowDialog"
                            Tag="HeavyView" />
                        <Button
                            Classes="DialogShowDialogAsyncWithCancelling"
                            Content="ToLightView:Dialog.ShowDialogWithCancelling"
                            Tag="LightView" />
                        <Button
                            Classes="WindowShow"
                            Content="ToLightView:Window.Show"
                            Tag="AWindow" />
                        <Button
                            Command="{Binding CollectCommand}"
                            Content="Collect"
                            Tag="" />
                    </StackPanel>
                </DockPanel>
            </SplitView.Pane>

            <DockPanel>
                <ContentControl an:RegionManager.RegionName="MainRegion" />
            </DockPanel>
        </SplitView>
        <SelectableTextBlock
            Name="footer"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>

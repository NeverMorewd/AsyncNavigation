<UserControl
    x:Class="Sample.Wpf.Views.TabRegionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:an="https://github.com/NeverMorewd/AsyncNavigation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Sample.Wpf.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource GoBack}" />
                <Button Style="{StaticResource GoForward}" />
            </StackPanel>
            <Button
                Content="ToLightView"
                Style="{StaticResource NavigationButton}"
                Tag="LightView" />
            <Button
                Content="ToHeavyView"
                Style="{StaticResource NavigationButton}"
                Tag="HeavyView" />
            <Button
                Content="ToHeavyView:Delay"
                Style="{StaticResource NavigationButton}"
                Tag="HeavyView:Delay" />
            <Button
                Content="ToLightView:New"
                Style="{StaticResource NavigationButton}"
                Tag="LightView:New" />
            <Button
                Content="ToHeavyView:New;Delay"
                Style="{StaticResource NavigationButton}"
                Tag="HeavyView:New;Delay" />
            <Button
                Content="ToLightView:Forget"
                Style="{StaticResource NavigationAndForget}"
                Tag="LightView" />
            <Button
                Content="ToLightView:Forget;New"
                Style="{StaticResource NavigationAndForget}"
                Tag="LightView:New" />
        </StackPanel>
        <ScrollViewer>
            <TabControl
                x:Name="tab"
                an:RegionManager.PreferCache="True"
                an:RegionManager.RegionName="TabRegion"
                TabStripPlacement="Top">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2" Orientation="Horizontal">
                            <ContentControl Content="{Binding Target.Value.DataContext.Icon, Converter={StaticResource IconDescriptorConverter}}" />
                            <TextBlock VerticalAlignment="Center" Text="{Binding ViewName}" />
                            <Button
                                Margin="10"
                                Command="{Binding DataContext.RequestUnloadViewCommand, ElementName=tab}"
                                CommandParameter="{Binding}"
                                Content="x" />
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
